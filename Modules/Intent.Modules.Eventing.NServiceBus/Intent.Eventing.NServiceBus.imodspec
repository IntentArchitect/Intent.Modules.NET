<?xml version="1.0" encoding="utf-8"?>
<package>
  <id>Intent.Eventing.NServiceBus</id>
  <version>1.0.0-pre.0</version>
  <supportedClientVersions>[5.0.0-a, 6.0.0-a)</supportedClientVersions>
  <summary>A custom module for Intent.Modules.NET</summary>
  <description>A custom module for Intent.Modules.NET</description>
  <authors>Intent.Modules.NET</authors>
  <iconUrl>data:image/svg+xml;base64,</iconUrl>
  <templates>
    <template id="Intent.Eventing.NServiceBus.NServiceBusConfiguration" externalReference="541e259d-2cd9-4c57-8a8f-d36f7eb21daf">
      <config>
        <add key="ClassName" description="Class name formula override (e.g. '${Model.Name}')" />
        <add key="Namespace" description="Class namespace formula override (e.g. '${Project.Name}'" />
      </config>
      <role>Infrastructure.DependencyInjection.NServiceBus</role>
      <location>Configuration</location>
    </template>
    <template id="Intent.Eventing.NServiceBus.NServiceBusMessageBus" externalReference="3915ea52-60d2-46e0-a827-44859cf211d0">
      <config>
        <add key="ClassName" description="Class name formula override (e.g. '${Model.Name}')" />
        <add key="Namespace" description="Class namespace formula override (e.g. '${Project.Name}'" />
      </config>
      <role>Application.Eventing.MessageBusImplementation</role>
      <location>Eventing</location>
    </template>
    <template id="Intent.Eventing.NServiceBus.NServiceBusMessageHandler" externalReference="17b4280e-2f8f-41c0-a70d-166cd3e351a8">
      <config>
        <add key="ClassName" description="Class name formula override (e.g. '${Model.Name}')" />
        <add key="Namespace" description="Class namespace formula override (e.g. '${Project.Name}'" />
      </config>
      <role>Infrastructure.Eventing.MessageHandler</role>
      <location>Eventing</location>
    </template>
  </templates>
  <decorators></decorators>
  <factoryExtensions>
    <factoryExtension id="Intent.Eventing.NServiceBus.NServiceBusRegistrationExtension" externalReference="99e6d024-7e01-4b4c-a56a-9dbb2aa8b836" />
  </factoryExtensions>
  <moduleSettings>
    <group id="76e5fbf4-95c3-4d3e-8343-0969c4a67df6" title="NServiceBusSettings" type="application-settings" externalReference="76e5fbf4-95c3-4d3e-8343-0969c4a67df6">
      <settings>
        <setting id="537d4def-c538-417c-bada-a785c14195b3" title="Transport" type="select">
          <defaultValue>learning-transport</defaultValue>
          <options>
            <option value="rabbitmq" description="RabbitMQ" />
            <option value="azure-service-bus" description="AzureServiceBus" />
            <option value="amazon-sqs" description="AmazonSQS" />
            <option value="sql-server" description="SqlServer" />
            <option value="learning-transport" description="LearningTransport" />
          </options>
        </setting>
        <setting id="4060477a-191f-43be-a2c1-f2dd94ff00e2" title="RecoverabilityPolicy" type="select">
          <hint>Determines which retry configuration blocks are generated. Values are read from appsettings.json at runtime.</hint>
          <defaultValue>immediate-and-delayed</defaultValue>
          <options>
            <option value="none" description="None" />
            <option value="immediate-only" description="ImmediateOnly" />
            <option value="delayed-only" description="DelayedOnly" />
            <option value="immediate-and-delayed" description="ImmediateAndDelayed" />
          </options>
        </setting>
      </settings>
    </group>
  </moduleSettings>
  <dependencies>
    <dependency id="Intent.Common" version="3.11.0" />
    <dependency id="Intent.Common.CSharp" version="3.10.5" />
    <dependency id="Intent.Common.Types" version="4.1.3" />
    <dependency id="Intent.Eventing.Contracts" version="6.1.0-pre.1" />
    <dependency id="Intent.Modelers.Services" version="4.0.7" />
    <dependency id="Intent.Modelers.Services.EventInteractions" version="2.0.0" />
    <dependency id="Intent.OutputManager.RoslynWeaver" version="4.10.4" />
  </dependencies>
  <files>
    <file src="$outDir$/$id$.dll" />
    <file src="$outDir$/$id$.pdb" />
  </files>
  <tags />
  <moduleSettingsExtensions />
  <metadata />
  <migrations />
