{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenApi": {
    "Oidc": {
      "AuthorizationUrl": "https://your-oauth-provider.com/connect/authorize",
      "Scopes": [
