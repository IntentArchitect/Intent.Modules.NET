{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Security.Bearer": {
    "Authority": "https://localhost:{sts_port}",
    "Audience": "api"
  },
  "CqrsSettings": {
    "LogRequestPayload": true
  },
  "IdentityClients": {
    "default": {
      "Address": "https://localhost:{sts_port}/connect/token",
      "ClientId": "clientId",
      "ClientSecret": "secret",
      "Scope": "api"
    }
  },
  "HttpClients": {
    "CleanArchitecture.SingleFiles.Services": {
      "Uri": "https://localhost:44357/;http://localhost:61414",
      "IdentityClientKey": "default",
      "Timeout": "00:01:00"
    }
  }
}