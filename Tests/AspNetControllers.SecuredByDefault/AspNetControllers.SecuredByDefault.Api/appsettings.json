{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IdentityClients": {
    "default": {
      "TokenEndpoint": "https://localhost:{sts_port}/connect/token",
      "ClientId": "clientId",
      "ClientSecret": "secret",
      "Scope": "api"
    }
  },
  "HttpClients": {
    "AspNetControllers.SecuredByDefault.Services": {
      "Uri": "https://localhost:44312/",
      "IdentityClientKey": "default",
      "Timeout": "00:01:00"
    }
  }
}